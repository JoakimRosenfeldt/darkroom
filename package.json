{
  "name": "darkroom",
  "version": "0.1.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build:next": "next build --webpack",
    "build:electron": "node electron/build.mjs",
    "build": "npm run build:next && npm run build:electron",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && npm run build:electron && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:start": "npm run build:electron && electron .",
    "dist": "npm run build && node scripts/package-release.mjs",
    "test": "node --no-warnings --experimental-strip-types --test tests/*.test.mts",
    "lint": "eslint",
    "postinstall": "node scripts/patch-libraw.mjs && node scripts/ensure-electron.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.3",
    "libraw-wasm": "^1.6.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "build": {
    "appId": "com.darkroom.app",
    "productName": "Darkroom",
    "files": [
      "electron-dist/**/*",
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.photography",
      "extraResources": [
        {
          "from": "${env.DARKROOM_NEF_SDK_FROM}/spike/DarkroomNefSpike.app/Contents",
          "to": "nikon-nef-decoder",
          "filter": [
            "MacOS/nikon-nef-decoder",
            "Frameworks/**/*",
            "Resources/**/*"
          ]
        },
        {
          "from": "${env.DARKROOM_NEF_SDK_FROM}/Image SDK/Library/Mac/Doc/Third Party Legal Notices.rtf",
          "to": "nikon-nef-decoder/Third Party Legal Notices.rtf"
        },
        {
          "from": "${env.DARKROOM_NEF_SDK_FROM}/spike/DarkroomNefSpike.app/Contents/Resources/prm.bin",
          "to": "prm.bin"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
